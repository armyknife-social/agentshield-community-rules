{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentshield.dev/schema/rule.schema.json",
  "title": "AgentShield Rule",
  "description": "JSON Schema for agentshield-rule-v0.1 YAML rule files.",
  "type": "object",
  "required": [
    "schema_version",
    "rule_id",
    "name",
    "description",
    "severity",
    "category",
    "content_types",
    "action",
    "detector"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "agentshield-rule-v0.1",
      "description": "Schema version identifier. Must be 'agentshield-rule-v0.1'."
    },
    "rule_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Unique kebab-case rule identifier."
    },
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128,
      "description": "Human-readable rule name."
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "description": "Full description of what this rule detects and why it is dangerous."
    },
    "severity": {
      "type": "string",
      "enum": ["HIGH", "MEDIUM", "LOW"],
      "description": "Rule severity level."
    },
    "category": {
      "type": "string",
      "description": "Rule category (e.g. prompt-injection, data-exfiltration, tool-abuse, llm-owasp)."
    },
    "content_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "user_input",
          "system_prompt",
          "assistant_output",
          "retrieval",
          "tool_call",
          "tool_result",
          "response"
        ]
      },
      "description": "Content pipeline locations where this rule is applied. 'response' is a legacy alias for 'assistant_output'."
    },
    "action": {
      "type": "string",
      "enum": ["block", "mirror", "warn", "log"],
      "description": "Action taken when the rule matches."
    },
    "detector": {
      "type": "object",
      "required": ["type"],
      "description": "Detector configuration.",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["regex", "heuristic", "model", "composite"],
          "description": "Detector implementation type."
        },
        "pattern": {
          "type": "string",
          "description": "Regex pattern string (required when type is 'regex')."
        },
        "signals": {
          "type": "array",
          "description": "Weighted signal list (used when type is 'heuristic').",
          "items": {
            "type": "object",
            "required": ["pattern", "weight"],
            "properties": {
              "pattern": {
                "type": "string"
              },
              "weight": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "additionalProperties": false
          }
        },
        "threshold": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Minimum cumulative signal weight to trigger (heuristic detectors)."
        }
      },
      "additionalProperties": true
    },
    "owasp_llm": {
      "type": "string",
      "pattern": "^LLM\\d{2}$",
      "description": "OWASP LLM Top 10 reference (e.g. LLM01, LLM09)."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Free-form tags for search and filtering. 'experimental' tag required for rules in rules/experimental/."
    },
    "mitigation": {
      "type": "string",
      "description": "Recommended mitigation or remediation steps when the rule fires."
    },
    "references": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      },
      "description": "External references (CVEs, research papers, OWASP pages, etc.)."
    },
    "test_cases": {
      "description": "Example inputs with expected outcomes for unit-testing the rule. Accepts either a list of {input, expected} objects (v0.1 style) or a dict with should_match / should_not_match lists (legacy style).",
      "oneOf": [
        {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["input", "expected"],
            "properties": {
              "input": {
                "type": "string"
              },
              "expected": {
                "type": "string",
                "enum": ["block", "mirror", "warn", "log", "pass"]
              }
            },
            "additionalProperties": false
          }
        },
        {
          "type": "object",
          "properties": {
            "should_match": {
              "type": "array",
              "items": { "type": "string" }
            },
            "should_not_match": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "author": {
      "type": "string",
      "description": "Rule author or 'community'."
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier (e.g. MIT, Apache-2.0)."
    }
  }
}
