{
  "name": "@agentshield/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for AgentShield — inspect content, manage sessions, query anomalies and receipts",
  "type": "module",
  "bin": {
    "agentshield-mcp": "./dist/index.js"
  },
